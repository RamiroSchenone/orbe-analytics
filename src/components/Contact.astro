---
// Componente de Contacto
---

<section id="contacto" class="py-20 scroll-component">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-center text-3xl md:text-5xl font-sans font-bold mb-12 scroll-component"><span class="text-orbe-violet">Contacto</span></h2>

    <div class="grid md:grid-cols-2 gap-12">
      <div class="fade-in-left space-y-6">
        <div>
          <h3 class="text-xl font-semibold text-soft-white">Dirección</h3>
          <p class="text-muted">Av. Cándido Carballo 580 · Rosario, Santa Fe</p>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-soft-white">Email</h3>
          <a class="text-orbe-violet hover:underline" href="mailto:nmo.carranza@gmail.com">nmo.carranza@gmail.com</a>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-soft-white">Teléfono / WhatsApp</h3>
          <a class="text-orbe-violet hover:underline" href="tel:+5493412741987">+54 9 341 2 741987</a>
          <span class="mx-1 text-muted">·</span>
          <a class="text-orbe-violet hover:underline" href="https://wa.me/5493412741987?text=Hola%20Orbe%20Analytics,%20quisiera%20coordinar%20una%20reuni%C3%B3n.">Escríbeme por WhatsApp</a>
        </div>
        <div class="flex gap-4 pt-2">
          <a href="https://www.instagram.com/orbeanalytics/" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-orbe-violet/20 grid place-items-center hover:bg-orbe-violet transition" aria-label="Instagram">
            <svg class="w-5 h-5 text-orbe-violet hover:text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/orbe-analytics/" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-orbe-violet/20 grid place-items-center hover:bg-orbe-violet transition" aria-label="LinkedIn">
            <svg class="w-5 h-5 text-orbe-violet hover:text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M6 9H3v12h3V9zm.2-4.2a1.8 1.8 0 1 0-3.6 0 1.8 1.8 0 0 0 3.6 0zM21 21h-3v-6.1c0-3.3-4-3-4 0V21h-3V9h3v1.8c1.4-2.6 7-2.8 7 2.5V21z"/></svg>
          </a>
        </div>
      </div>

      <!-- Netlify Forms -->
      <form
        id="contact-form"
        name="contacto-orbe"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/gracias"
        class="fade-in-right space-y-4"
      >
        <input type="hidden" name="form-name" value="contacto-orbe" />
        <p class="hidden">
          <label>Si eres humano, deja esto vacío: <input name="bot-field" /></label>
        </p>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="contact-nombre" class="block text-sm mb-1">Nombre</label>
            <input
              id="contact-nombre"
              name="nombre"
              required
              class="w-full rounded-lg bg-white/[0.05] border border-white/10 px-4 py-3 outline-none focus:ring-2 focus:ring-orbe-violet focus:ring-offset-2 focus:ring-offset-[#0e0e0e] focus:border-orbe-violet/50 transition-all duration-200"
            />
            <p class="contact-error text-red-400 text-xs mt-1 hidden"></p>
          </div>
          <div>
            <label for="contact-email" class="block text-sm mb-1">Email</label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              class="w-full rounded-lg bg-white/[0.05] border border-white/10 px-4 py-3 outline-none focus:ring-2 focus:ring-orbe-violet focus:ring-offset-2 focus:ring-offset-[#0e0e0e] focus:border-orbe-violet/50 transition-all duration-200"
            />
            <p class="contact-error text-red-400 text-xs mt-1 hidden"></p>
          </div>
        </div>

        <div>
          <label for="contact-mensaje" class="block text-sm mb-1">Mensaje</label>
          <textarea
            id="contact-mensaje"
            name="mensaje"
            rows="4"
            required
            class="w-full rounded-lg bg-white/[0.05] border border-white/10 px-4 py-3 outline-none focus:ring-2 focus:ring-orbe-violet focus:ring-offset-2 focus:ring-offset-[#0e0e0e] focus:border-orbe-violet/50 transition-all duration-200 resize-none"
          ></textarea>
          <p class="contact-error text-red-400 text-xs mt-1 hidden"></p>
        </div>

        <button
          id="contact-submit"
          type="submit"
          class="w-full sm:w-auto bg-orbe-violet hover:bg-purple-600 px-6 py-3 rounded-lg font-semibold transition-all duration-200 hover:-translate-y-0.5"
        >Enviar</button>
        <p class="text-xs text-gray-400">Al enviar aceptas ser contactado por Orbe Analytics.</p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

  function showError(input: HTMLElement, msg: string) {
    const err = input.parentElement?.querySelector('.contact-error') as HTMLElement;
    if (err) { err.textContent = msg; err.classList.remove('hidden'); }
    input.classList.add('border-red-500/60');
    input.classList.remove('border-white/10');
  }

  function clearError(input: HTMLElement) {
    const err = input.parentElement?.querySelector('.contact-error') as HTMLElement;
    if (err) { err.classList.add('hidden'); }
    input.classList.remove('border-red-500/60');
    input.classList.add('border-white/10');
  }

  const nombre = document.getElementById('contact-nombre') as HTMLInputElement;
  const email = document.getElementById('contact-email') as HTMLInputElement;
  const mensaje = document.getElementById('contact-mensaje') as HTMLTextAreaElement;

  nombre?.addEventListener('blur', () => {
    if (!nombre.value.trim()) showError(nombre, 'El nombre es requerido.');
    else clearError(nombre);
  });

  email?.addEventListener('blur', () => {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email.value.trim()) showError(email, 'El email es requerido.');
    else if (!re.test(email.value)) showError(email, 'Email inválido.');
    else clearError(email);
  });

  mensaje?.addEventListener('blur', () => {
    if (mensaje.value.trim().length < 10) showError(mensaje, 'El mensaje debe tener al menos 10 caracteres.');
    else clearError(mensaje);
  });

  form?.addEventListener('submit', () => {
    if (submitBtn) {
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-60', 'cursor-not-allowed');
    }
  });
</script>
