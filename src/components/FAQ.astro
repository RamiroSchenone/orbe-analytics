---
// Componente de FAQ
---

<style>
  .faq-item {
    transition: border-left 0.3s ease;
  }
  .faq-item--open {
    border-left: 2px solid var(--orbe-violet);
  }
</style>

<section id="faq" class="py-20 gradient-bg scroll-component">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-center text-3xl md:text-5xl font-sans font-bold mb-14 scroll-component">Preguntas <span class="text-orbe-violet">Frecuentes</span></h2>

    <div class="space-y-4">
      <!-- FAQ 1 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="1" aria-expanded="false" aria-controls="faq-answer-1">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">01</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Qué servicios ofrecen?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-1" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">Ofrecemos integración de datos, diseño de Data Warehouses y dashboards, analítica avanzada y consultoría estratégica. Nuestro enfoque combina experiencia técnica con una visión humana del cambio, asegurando que las soluciones tecnológicas se adapten al ritmo y necesidades de tu equipo.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 2 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in fade-in-delay-1 hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="2" aria-expanded="false" aria-controls="faq-answer-2">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">02</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Cómo pueden ayudarme?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-2" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">Convertimos datos dispersos en información accionable y acompañamos a tu equipo en el proceso de adopción. Diseñamos juntos los tableros y modelos para que comprendan su lógica y se sientan seguros al usarlos. Fomentamos un entorno de aprendizaje progresivo, donde preguntar y experimentar es parte del proceso, para que tu organización crezca con foco y rapidez sin perder confianza.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 3 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in fade-in-delay-2 hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="3" aria-expanded="false" aria-controls="faq-answer-3">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">03</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Qué es la integración?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-3" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">Es el proceso de unificar múltiples fuentes y sistemas en una única versión de la verdad, con calidad y trazabilidad. Más allá de la tecnología, ayudamos a que las áreas involucradas entiendan y validen los datos que consumen, construyendo puentes entre procesos, personas y tecnología para mejorar la colaboración.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 4 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in fade-in-delay-3 hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="4" aria-expanded="false" aria-controls="faq-answer-4">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">04</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Cómo empezar?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-4" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">Agenda una reunión de diagnóstico sin costo para delinear un roadmap a medida. En ese primer encuentro, además de analizar requerimientos técnicos, escuchamos las inquietudes de tu equipo y les mostramos ejemplos prácticos para que visualicen el valor desde el inicio. Nuestro objetivo es que cada paso combine solidez técnica con acompañamiento humano, garantizando una adopción sostenida.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 5 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in fade-in-delay-4 hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="5" aria-expanded="false" aria-controls="faq-answer-5">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">05</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Cuánto tiempo toma implementar una solución?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-5" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">El tiempo de implementación varía según la complejidad del proyecto. Proyectos básicos de dashboards pueden completarse en 2-4 semanas, mientras que integraciones complejas pueden tomar 2-6 meses. Trabajamos con metodologías ágiles para entregar valor incremental y mantener la flexibilidad durante el proceso.</p>
          </div>
        </div>
      </div>

      <!-- FAQ 6 -->
      <div class="faq-item card-gradient rounded-xl overflow-hidden fade-in fade-in-delay-5 hover-lift">
        <button class="faq-question w-full p-6 text-left flex items-center justify-between cursor-pointer transition-all duration-300 hover:bg-orbe-violet/5" data-faq="6" aria-expanded="false" aria-controls="faq-answer-6">
          <div class="flex items-center gap-4">
            <span class="text-orbe-violet/40 text-sm font-mono select-none flex-shrink-0">06</span>
            <h3 class="text-lg md:text-xl font-semibold text-soft-white">¿Ofrecen soporte y mantenimiento?</h3>
          </div>
          <span class="faq-icon transition-transform duration-300 flex-shrink-0 ml-4">
            <svg class="w-5 h-5 text-orbe-violet" viewBox="0 0 24 24" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </button>
        <div id="faq-answer-6" class="faq-answer max-h-0 overflow-hidden transition-all duration-500 ease-out">
          <div class="px-6 pb-6 pt-2 pl-16">
            <p class="text-muted">Sí, ofrecemos planes de soporte y mantenimiento continuo para asegurar el funcionamiento óptimo de las soluciones implementadas. Incluye monitoreo proactivo, actualizaciones, capacitación adicional y soporte técnico. Nuestro objetivo es que tu equipo se sienta acompañado en todo momento.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  let activeFaq: string | null = null;

  function toggleFaq(faqId: string) {
    const faqItem = (document.querySelector(`[data-faq="${faqId}"]`) as HTMLElement)?.closest('.faq-item') as HTMLElement;
    const faqAnswer = faqItem?.querySelector('.faq-answer') as HTMLElement;
    const faqIcon = faqItem?.querySelector('.faq-icon') as HTMLElement;
    const faqQuestion = faqItem?.querySelector('.faq-question') as HTMLElement;
    if (!faqItem || !faqAnswer) return;

    if (activeFaq === faqId) {
      faqAnswer.style.maxHeight = '0';
      faqIcon.style.transform = 'rotate(0deg)';
      faqQuestion.classList.remove('bg-orbe-violet/10', 'ring-1', 'ring-orbe-violet/30');
      faqQuestion.setAttribute('aria-expanded', 'false');
      faqItem.classList.remove('faq-item--open');
      activeFaq = null;
    } else {
      if (activeFaq) {
        const prev = (document.querySelector(`[data-faq="${activeFaq}"]`) as HTMLElement)?.closest('.faq-item') as HTMLElement;
        if (prev) {
          (prev.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '0';
          (prev.querySelector('.faq-icon') as HTMLElement).style.transform = 'rotate(0deg)';
          const prevQ = prev.querySelector('.faq-question') as HTMLElement;
          prevQ.classList.remove('bg-orbe-violet/10', 'ring-1', 'ring-orbe-violet/30');
          prevQ.setAttribute('aria-expanded', 'false');
          prev.classList.remove('faq-item--open');
        }
      }
      faqAnswer.style.maxHeight = faqAnswer.scrollHeight + 'px';
      faqIcon.style.transform = 'rotate(180deg)';
      faqQuestion.classList.add('bg-orbe-violet/10', 'ring-1', 'ring-orbe-violet/30');
      faqQuestion.setAttribute('aria-expanded', 'true');
      faqItem.classList.add('faq-item--open');
      activeFaq = faqId;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-faq');
        if (id) toggleFaq(id);
      });
    });
  });
</script>
