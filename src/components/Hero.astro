---
// Componente de Hero Section
---

<header id="inicio" class="hero-gradient min-h-screen flex items-center relative overflow-hidden">
  <!-- Overlay que se desvanece al hacer scroll -->
  <div class="hero-overlay absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-orbe-dark/50 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-20 sm:py-24 md:py-16 relative z-10 w-full">
    <div class="max-w-4xl hero-content">
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif font-bold leading-tight animate-fade-in-up text-soft-white">
        Primero <span class="text-orbe-violet animate-pulse">los datos</span>
      </h1>
      
      <!-- Leyenda principal con animación sutil -->
      <p class="hero-subtitle mt-4 sm:mt-6 text-base sm:text-lg md:text-xl text-muted leading-relaxed animate-fade-in-up animation-delay-200">
        Impulsamos una cultura organizacional orientada a los datos, donde la información fluye de manera integrada, confiable y trazable a lo largo de todo su recorrido.
      </p>
      
      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 animate-fade-in-up animation-delay-400">
        <a href="#servicios" class="inline-flex justify-center bg-orbe-violet hover:bg-purple-600 text-white px-6 sm:px-7 py-3 sm:py-3 rounded-lg font-medium hover-lift text-sm sm:text-base transition-all duration-300 hover:scale-105">Descubre</a>
        <a href="#contacto" class="inline-flex justify-center border-2 border-white hover:bg-white hover:text-orbe-dark px-6 sm:px-7 py-3 sm:py-3 rounded-lg font-medium hover-lift text-sm sm:text-base transition-all duration-300 hover:scale-105">Contáctanos</a>
      </div>
      
    </div>
  </div>
</header>
