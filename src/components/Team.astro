---
// Agregar fotos en: public/team/[nombre-apellido].jpg (portrait o 1:1, mínimo 600px)
// Para agregar un miembro, duplicar un objeto del array y editar sus campos.

interface TeamMember {
  name?: string;
  role: string;
  photo: string;
  linkedin?: string;
}

const team: TeamMember[] = [
  {
    name: "Nicolás Thess",
    role: "Fundador & Lead BI",
    photo: "/team/bi-ba.png",
    linkedin: "https://www.linkedin.com/in/nicolasthess",
  },
  {
    role: "Desarrollo de Software",
    photo: "/team/programmer.png",
  },
  {
    role: "Ciberseguridad",
    photo: "/team/cibersecurity.png",
  },
  {
    role: "Community Manager",
    photo: "/team/community-manager.png",
  },
  {
    role: "Diseño Gráfico",
    photo: "/team/graphic-design.png",
  },
];

function getInitials(name?: string): string {
  if (!name) return "";
  return name
    .split(" ")
    .slice(0, 2)
    .map((n) => n[0]?.toUpperCase() ?? "")
    .join("");
}
---

<section id="equipo" class="py-16 sm:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Encabezado editorial: label + heading izquierda, descripción derecha -->
    <div class="mb-12 sm:mb-16 fade-in">
      <p class="text-xs sm:text-sm font-semibold tracking-[0.25em] uppercase text-orbe-violet mb-4">El equipo</p>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 lg:gap-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-sans font-bold text-soft-white leading-tight">
          Quiénes <span class="text-orbe-violet">somos</span>
        </h2>
        <p class="text-muted text-base sm:text-lg lg:max-w-sm lg:text-right lg:pb-1">
          Profesionales comprometidos con transformar datos en valor real para tu organización.
        </p>
      </div>
      <div class="mt-6 sm:mt-8 h-px" style="background: linear-gradient(90deg, rgba(139,92,246,0.4) 0%, rgba(255,255,255,0.04) 60%, transparent 100%);"></div>
    </div>

    <!-- Grid del equipo -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5 sm:gap-6 lg:gap-5">
      {team.map((member, i) => (
        <article
          class={`group relative overflow-hidden rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:border-orbe-violet/25 hover:shadow-2xl hover:shadow-orbe-violet/10 transition-all duration-500 fade-in`}
          style={`transition-delay: ${i * 0.1}s`}
        >

          <!-- Contenedor de foto -->
          <div class="relative overflow-hidden aspect-[3/4]">

            <!-- Fallback con iniciales (visible si la foto no carga) -->
            <div
              class="absolute inset-0 flex flex-col items-center justify-center"
              style="background: linear-gradient(145deg, rgba(139,92,246,0.22) 0%, rgba(88,28,135,0.45) 100%);"
              aria-hidden="true"
            >
              <span
                class="text-7xl font-bold select-none font-sans"
                style="color: rgba(255,255,255,0.22);"
              >
                {getInitials(member.name)}
              </span>
            </div>

            <!-- Foto del integrante -->
            <img
              src={member.photo}
              alt={`Foto de ${member.name}`}
              class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
              loading="lazy"
              onerror="this.style.opacity='0'"
            />

            <!-- Degradado inferior que unifica foto con info -->
            <div
              class="absolute bottom-0 inset-x-0 h-2/5 pointer-events-none z-10"
              style="background: linear-gradient(to top, #0e0e0e 0%, transparent 100%);"
            ></div>

            <!-- Línea de acento superior (aparece en hover) -->
            <div
              class="absolute top-0 inset-x-0 h-[2px] opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"
              style="background: linear-gradient(90deg, transparent 0%, #8B5CF6 50%, transparent 100%);"
            ></div>
          </div>

          <!-- Info -->
          <div class="px-5 pb-6 pt-1 relative z-10">
            <div class="flex items-center gap-2 mb-1.5">
              <div class="w-1.5 h-1.5 rounded-full bg-orbe-violet/60 group-hover:bg-orbe-violet transition-colors duration-300 flex-shrink-0"></div>
              <span
                class="text-xs font-medium tracking-[0.15em] uppercase"
                style="color: rgba(139,92,246,0.8);"
              >
                {member.role}
              </span>
            </div>

            <div class="flex items-center justify-between gap-3">
              {member.name && (
                <h3 class="text-lg sm:text-xl font-sans font-semibold text-soft-white leading-snug">
                  {member.name}
                </h3>
              )}

              {member.linkedin && (
                <a
                  href={member.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-shrink-0 w-9 h-9 rounded-lg bg-white/5 border border-white/[0.08] hover:bg-orbe-violet/15 hover:border-orbe-violet/30 flex items-center justify-center transition-all duration-300 cursor-pointer"
                  aria-label={`LinkedIn de ${member.name ?? member.role}`}
                >
                  <svg
                    class="w-4 h-4 transition-colors duration-300"
                    style="color: rgba(255,255,255,0.35);"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
