---
// OrbeCube — GLB model with custom chrome materials + brand lighting
---

<div id="orbe-cube-container" class="absolute inset-0" aria-hidden="true">
  <canvas id="orbe-cube-canvas" class="w-full h-full block"></canvas>
  <div class="orbe-cube-glow absolute left-1/2 pointer-events-none" style="top: 65%; transform: translateX(-50%);"></div>
</div>

<style>
  #orbe-cube-container {
    animation: cube-enter 0.8s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
    transition: transform 0.4s cubic-bezier(0.34, 1.4, 0.64, 1);
  }

  #orbe-cube-container:hover {
    transform: scale(1.06);
  }

  @keyframes cube-enter {
    from { opacity: 0; transform: scale(0.55); }
    to   { opacity: 1; transform: scale(1); }
  }

  .orbe-cube-glow {
    width: 55%;
    height: 40px;
    background: radial-gradient(
      ellipse 100% 100% at 50% 100%,
      rgba(139, 92, 246, 0.22) 0%,
      transparent 100%
    );
    filter: blur(8px);
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  function initCube() {
    const container = document.getElementById('orbe-cube-container') as HTMLElement;
    const canvas    = document.getElementById('orbe-cube-canvas') as HTMLCanvasElement;
    if (!container || !canvas) return;

    // --- Renderer ---
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.4;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    // --- Scene + Camera ---
    const scene  = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
    camera.position.set(0, 0, 5);
    camera.lookAt(0, 0, 0);

    // --- Environment map (dark-to-violet gradient for chrome reflections) ---
    const pmrem = new THREE.PMREMGenerator(renderer);
    pmrem.compileEquirectangularShader();
    const envSize = 64;
    const envData = new Uint8Array(envSize * envSize * 4);
    for (let y = 0; y < envSize; y++) {
      for (let x = 0; x < envSize; x++) {
        const i = (y * envSize + x) * 4;
        const t = y / envSize;
        envData[i]     = Math.round(6  + t * 28);
        envData[i + 1] = Math.round(2  + t * 8);
        envData[i + 2] = Math.round(20 + t * 90);
        envData[i + 3] = 255;
      }
    }
    const envTex = new THREE.DataTexture(envData, envSize, envSize);
    envTex.needsUpdate = true;
    scene.environment = pmrem.fromEquirectangular(envTex).texture;
    pmrem.dispose();
    envTex.dispose();

    // --- Lighting — neutral to preserve original GLB materials ---
    const keyLight = new THREE.DirectionalLight(0xffffff, 2.5);
    keyLight.position.set(5, 8, 5);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0xffffff, 1.0);
    fillLight.position.set(-4, 2, 3);
    scene.add(fillLight);

    scene.add(new THREE.AmbientLight(0xffffff, 1.2));

    // --- Load GLB model ---
    const loader = new GLTFLoader();
    let rotator: THREE.Group;  // only rotates — origin = cube center
    let floater: THREE.Group;  // only floats Y — stays at fixed world position

    loader.load('/orbecube.glb', (gltf) => {
      const model = gltf.scene;

      // Compute bounding box from visible mesh geometry only
      model.updateMatrixWorld(true);
      const box = new THREE.Box3();
      model.traverse((child) => {
        if (child instanceof THREE.Mesh && child.visible) {
          child.geometry.computeBoundingBox();
          const geomBox = child.geometry.boundingBox!.clone();
          geomBox.applyMatrix4(child.matrixWorld);
          box.union(geomBox);
        }
      });
      const center = box.getCenter(new THREE.Vector3());
      const size   = box.getSize(new THREE.Vector3());
      const maxDim = Math.max(size.x, size.y, size.z);

      // Scale first, then offset by -center*scale so world center = 0
      // (doing position.sub(center) then scale undoes the centering: world center = C*(s-1))
      const s = 2.6 / maxDim;
      model.scale.setScalar(s);
      model.position.set(-center.x * s, -center.y * s, -center.z * s);

      // rotator: holds the model, rotates around centered origin
      rotator = new THREE.Group();
      rotator.add(model);

      // floater: parent of rotator, only moves Y for float effect
      floater = new THREE.Group();
      floater.add(rotator);
      scene.add(floater);
    },
    undefined,
    (err) => console.error('GLB load error:', err));

    // --- Resize ---
    function resize() {
      const w = container.clientWidth;
      const h = container.clientHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    const ro = new ResizeObserver(resize);
    ro.observe(container);

    // --- Animate ---
    // --- Mouse drag with inertia ---
    let isDragging = false;
    let lastX = 0, lastY = 0;
    let velX = 0, velY = 0;  // angular velocity in radians/frame
    const DAMPING    = 0.92;  // friction — lower = stops faster
    const AUTO_SPEED = 0.006; // auto-rotate speed when idle
    const AUTO_THRESHOLD = 0.0002; // velocity below this → resume auto-rotate

    canvas.style.cursor = 'grab';

    canvas.addEventListener('mousedown', (e) => {
      isDragging = true;
      velX = 0; velY = 0;
      lastX = e.clientX;
      lastY = e.clientY;
      canvas.style.cursor = 'grabbing';
    });

    const worldY = new THREE.Vector3(0, 1, 0);
    const worldX = new THREE.Vector3(1, 0, 0);

    function applyDelta(dx: number, dy: number) {
      if (!rotator) return;
      const qY = new THREE.Quaternion().setFromAxisAngle(worldY, dx);
      const qX = new THREE.Quaternion().setFromAxisAngle(worldX, dy);
      rotator.quaternion.premultiply(qY).premultiply(qX);
    }

    window.addEventListener('mousemove', (e) => {
      if (!isDragging || !rotator) return;
      const dx = e.clientX - lastX;
      const dy = e.clientY - lastY;
      velY = dx * 0.012;
      velX = dy * 0.012;
      applyDelta(velY, velX);
      lastX = e.clientX;
      lastY = e.clientY;
    });

    window.addEventListener('mouseup', () => {
      isDragging = false;
      canvas.style.cursor = 'grab';
    });

    // Touch
    canvas.addEventListener('touchstart', (e) => {
      isDragging = true;
      velX = 0; velY = 0;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
    }, { passive: true });

    canvas.addEventListener('touchmove', (e) => {
      if (!isDragging || !rotator) return;
      const dx = e.touches[0].clientX - lastX;
      const dy = e.touches[0].clientY - lastY;
      velY = dx * 0.012;
      velX = dy * 0.012;
      applyDelta(velY, velX);
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
    }, { passive: true });

    canvas.addEventListener('touchend', () => { isDragging = false; });

    // --- Animate ---
    let animId: number;
    const clock = new THREE.Clock();
    function animate() {
      animId = requestAnimationFrame(animate);
      const t = clock.getElapsedTime();

      if (rotator) {
        if (isDragging) {
          // dragging — velocity set by mousemove
        } else {
          // apply inertia
          velX *= DAMPING;
          velY *= DAMPING;
          applyDelta(velY, velX);

          // auto-rotate only when momentum has died out
          const speed = Math.abs(velX) + Math.abs(velY);
          if (speed < AUTO_THRESHOLD) {
            velX = 0; velY = 0;
            applyDelta(AUTO_SPEED, 0);
          }
        }
      }

      // no float — fixed position
      renderer.render(scene, camera);
    }
    animate();

    // --- Cleanup ---
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
      renderer.dispose();
    }, { once: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCube);
  } else {
    initCube();
  }
</script>
