---
import logoWhite from '../assets/LOGO PNG BLANCO.png';
---

<footer class="border-t border-white/[0.06] py-10 sm:py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 items-start">

      <!-- Logo -->
      <div>
        <a href="#inicio" class="inline-block logo-link hover:opacity-80 transition-opacity duration-300">
          <img src={logoWhite.src} alt="Orbe Analytics" class="h-16 sm:h-20 w-auto">
        </a>
      </div>

      <!-- Quick links -->
      <div class="flex flex-col gap-2">
        <p class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-1">Navegación</p>
        <a href="#servicios" class="text-sm text-muted hover:text-orbe-violet transition-colors duration-200">Servicios</a>
        <a href="#sobre-nosotros" class="text-sm text-muted hover:text-orbe-violet transition-colors duration-200">Sobre nosotros</a>
        <a href="#faq" class="text-sm text-muted hover:text-orbe-violet transition-colors duration-200">FAQ</a>
        <a href="#contacto" class="text-sm text-muted hover:text-orbe-violet transition-colors duration-200">Contacto</a>
      </div>

      <!-- Social + location -->
      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-white/30 mb-1">Redes</p>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/orbeanalytics/" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-full bg-orbe-violet/15 grid place-items-center hover:bg-orbe-violet/30 transition-colors duration-200"
             aria-label="Instagram">
            <svg class="w-4 h-4 text-orbe-violet" viewBox="0 0 24 24" fill="currentColor">
              <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/orbe-analytics/" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-full bg-orbe-violet/15 grid place-items-center hover:bg-orbe-violet/30 transition-colors duration-200"
             aria-label="LinkedIn">
            <svg class="w-4 h-4 text-orbe-violet" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 9H3v12h3V9zm.2-4.2a1.8 1.8 0 1 0-3.6 0 1.8 1.8 0 0 0 3.6 0zM21 21h-3v-6.1c0-3.3-4-3-4 0V21h-3V9h3v1.8c1.4-2.6 7-2.8 7 2.5V21z"/>
            </svg>
          </a>
        </div>
        <p class="text-xs text-white/30 flex items-center gap-1.5 mt-1">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" stroke="currentColor" stroke-width="2"/></svg>
          Rosario, Argentina
        </p>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-white/[0.05] text-center">
      <p class="text-xs text-white/25">© 2025 Orbe Analytics. Transformando datos en decisiones estratégicas.</p>
    </div>
  </div>
</footer>
