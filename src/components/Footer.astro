---
// Componente de Footer reutilizable
import logoWhite from '../assets/LOGO PNG BLANCO.png';
---

<footer class="bg-orbe-gray py-6 sm:py-8 border-t border-orbe-violet/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <a href="#inicio" class="flex items-center gap-2 logo-link hover:scale-105 transition-transform duration-300">
        <img src={logoWhite.src} alt="Orbe Analytics" class="h-16 sm:h-20 md:h-24 lg:h-[150px] w-auto">
    </a>
    <p class="text-muted text-center md:text-right text-sm sm:text-base animate-fade-in-up">© 2025 Orbe Analytics. Transformando datos en decisiones estratégicas.</p>
  </div>
</footer>
